@inject IJobRepository JobRepo

<div class="card-single">
    <div class="card-flex">
        <div class="card-info">
            <div class="card-head">
                <span>Total Tasks</span>
                <small>The Number of Total Tasks:</small>
            </div>
            <h2>@JobRepo.GetTotalRecordsNumber() Tasks</h2>
        </div>
        <div class="card-chart success">
            <span class="las la-chart-line"></span>
        </div>
    </div>
</div>

<div class="card-single">
    <div class="card-flex">
        <div class="card-info">
            <div class="card-head">
                <span>Commpleted Tasks</span>
                <small>Number of Completed Tasks</small>
            </div>
            <h2>@JobRepo.GetTotalCompletedTasks() Tasks</h2>
        </div>
        @if(JobRepo.GetTotalCompletedTasks() > JobRepo.GetTotalRecordsNumber()/2)
        {
            <div class="card-chart success">
                <span class="las la-chart-line"></span>
            </div>
        }
        else
        {
            <div class="card-chart yellow">
                <span class="las la-chart-line"></span>
            </div>
        }
    </div>
</div>

<div class="card-single">
    <div class="card-flex">
        <div class="card-info">
            <div class="card-head">
                <span>Must Done Today</span>
                <small>Tasks To Finished Necessary Today </small>
            </div>

            <h2>@JobRepo.GetAll().Where(x => x.DeadLine == DateOnly.FromDateTime(DateTime.Now)).Count() Tasks</h2>
        </div>
        <div class="card-chart yellow">
            <span class="las la-chart-line"></span>
        </div>
    </div>
</div>